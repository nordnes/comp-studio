{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(npm run test)",
      "Bash(npm test)",
      "Bash(node engine.test.mjs)",
      "Bash(node engine/engine.test.mjs)",
      "Bash(node scaffold/engine.test.mjs)",
      "Bash(vp dev)",
      "Bash(vp check)",
      "Bash(vp build)",
      "Bash(vp test)",
      "Bash(vp preview)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Read(./engine/engine.ts)"
    ]
  }
}
